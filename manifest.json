{
  "id": "/belajarpwapertama/",
  "name": "FEELZ - AI Writing Assistant",
  "short_name": "FEELZ",
  "description": "Aplikasi PWA responsif AI Writing Assistant dengan fitur parafrase, editor, terjemahan, dan analisis teks. Mendukung mode offline dan dapat diinstal.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "standalone",
    "window-controls-overlay",
    "tabbed"
  ],
  "background_color": "#1856bb",
  "theme_color": "#1856bb",
  "orientation": "any",
  "lang": "id",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    {
      "origin": "https://duhitagaluh-jn.github.io"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/plain": [".txt"],
        "text/markdown": [".md"]
      }
    }
  ],
  "widgets": [
    {
      "name": "FEELZ Quick Write",
      "short_name": "FEELZ Widget",
      "description": "Widget cepat untuk menulis dan edit teks dengan AI",
      "tag": "feelz-widget",
      "ms_ac_template": "widgets/widget-template.json",
      "data": "./index.html",
      "type": "application/json",
      "screenshots": [
        {
          "src": "icons/screenshot1.png",
          "sizes": "1442x3090",
          "label": "FEELZ Widget Preview"
        }
      ],
      "icons": [
        {
          "src": "icons/logo-512x512.png",
          "sizes": "512x512"
        }
      ]
    }
  ],
  "note_taking": {
    "new_note_url": "./index.html?mode=note"
  },
  "categories": [
    "productivity",
    "utilities",
    "education"
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "icons": [
    {
      "src": "icons/logo-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
